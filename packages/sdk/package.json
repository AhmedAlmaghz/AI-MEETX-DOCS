{
  "name": "@aimeetx/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "AI MeetX SDK — single source of truth for all business logic, events, network, storage, and AI integration. Consumed by web, desktop, mobile, and 3rd-party clients.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@aimeetx/events": "workspace:*",
    "@aimeetx/network": "workspace:*",
    "@aimeetx/storage": "workspace:*",
    "@aimeetx/types": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsyringe": "^4.8.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}