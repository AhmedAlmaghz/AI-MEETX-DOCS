{
  "name": "@aimeetx/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared configuration presets for the AI MeetX monorepo — TypeScript, ESLint, Prettier.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tsconfig/library.json": "./tsconfig/library.json",
    "./tsconfig/app.json": "./tsconfig/app.json",
    "./tsconfig/react.json": "./tsconfig/react.json"
  },
  "files": ["dist", "tsconfig"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}