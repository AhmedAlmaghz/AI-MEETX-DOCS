{
  "name": "@aimeetx/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for the AI MeetX platform — Result, branded IDs, and cross-package domain primitives.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .turbo coverage *.tsbuildinfo"
  },
  "devDependencies": {
    "@aimeetx/config": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}