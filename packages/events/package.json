{
  "name": "@aimeetx/events",
  "version": "0.1.0",
  "private": true,
  "description": "Typed event bus for the AI MeetX platform — RxJS-based, the only mechanism for cross-module communication within the SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist .turbo coverage *.tsbuildinfo"
  },
  "dependencies": {
    "@aimeetx/types": "workspace:*",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}