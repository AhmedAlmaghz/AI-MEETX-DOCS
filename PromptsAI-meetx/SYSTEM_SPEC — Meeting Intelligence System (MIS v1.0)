    purpose: "Extract structured intelligence from meetings",
    entities: [
        "Decision",
        "ActionItem",
        "Insight"
    ],
    value_objects: [
        "ConfidenceScore"
    ],
    aggregates: [
        "IntelligenceAggregate"
    ],
    domain_events: [
        "DecisionExtracted",
        "ActionItemCreated"
    ],
    rules: [
        "Every decision must have a source transcript reference"
    ],
    relationships: [
        "Decisions generate ActionItems"
    ]
}

]
}
