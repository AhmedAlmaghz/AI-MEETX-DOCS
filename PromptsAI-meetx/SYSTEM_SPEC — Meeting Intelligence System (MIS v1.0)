# ROLES

```text id="mis-roles"
roles {

{
    role_id: "ROLE-MEETING-COORDINATOR",
    name: "Meeting Coordinator",
    responsibilities: [
        "Manage meeting lifecycle",
        "Track participants",
        "Control agenda flow"
    ],
    inputs: ["meeting_request"],
    outputs: ["meeting_session"],
    permissions: ["create_meeting", "end_meeting"],
    constraints: ["no decision authority"],
    domain_mapping: "Meeting Management"
},

{
    role_id: "ROLE-AI-ANALYST",
    name: "AI Meeting Analyst",
    responsibilities: [
        "Extract decisions",
        "Generate action items",
        "Detect insights"
    ],
    inputs: ["transcript"],
    outputs: ["decisions", "actions", "insights"],
    permissions: ["read_transcript"],
    constraints: ["cannot modify meeting data"],
    domain_mapping: "Meeting Intelligence"
}

}
}
```

